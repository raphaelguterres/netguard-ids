# NetGuard IDS - environment example
# Copy to .env and adjust values for your environment.
# Never commit the real .env file.

############################
# Server
############################

IDS_ENV=development
IDS_HOST=127.0.0.1
IDS_PORT=5000
HTTPS_ONLY=false
APP_URL=https://your-domain.example

############################
# Database
############################

# Leave unset for local SQLite.
# Use PostgreSQL for production.
# DATABASE_URL=postgresql://netguard:strong_password@localhost:5432/netguard

# Modular EDR repository used by /api/events and /soc/grid.
# Leave unset to use ./netguard_edr.db next to app.py.
# NETGUARD_EDR_DB=netguard_edr.db

############################
# Authentication
############################

# Local-only dev can run with IDS_AUTH=false on loopback.
# Production should use IDS_AUTH=true.
IDS_AUTH=false
IDS_DASHBOARD_AUTH=true

# Required outside dev/test.
TOKEN_SIGNING_SECRET=replace-with-a-strong-random-secret

# Optional Flask/session secret if needed by extensions.
# SECRET_KEY=replace-with-another-strong-secret

# Explicit local-lab bypass only. Never enable in production.
# IDS_ALLOW_INSECURE_DEV=true

# Disable only in automated tests or isolated local debugging.
# IDS_CSRF_DISABLED=true

############################
# Agent runtime helpers
############################

# Keys accepted by the modular /api/events ingest endpoint.
# Comma-separated list for lab/dev; use rotated per-host keys in production.
# NETGUARD_AGENT_KEYS=nga_dev_one,nga_dev_two
#
# Modular /api/events rate limit. Default is in-memory for local/dev.
# Use sqlite on single-host production so multiple WSGI workers share budget.
# NETGUARD_RATE_LIMIT_BACKEND=sqlite
# NETGUARD_RATE_LIMIT_DB=/var/lib/netguard/netguard_rate_limit.db
# NETGUARD_RATE_LIMIT_RATE_PER_SEC=20
# NETGUARD_RATE_LIMIT_BURST=40
#
# The new agent runtime lives in ./agent and reads its own config.yaml,
# but these vars are useful for wrappers/services:
# NETGUARD_AGENT_API_KEY=nga_...
# NETGUARD_AGENT_SERVER_URL=https://127.0.0.1:5000/api/events
# NETGUARD_AGENT_CONFIG=C:\Program Files\NetGuard\Agent\config.yaml
# NETGUARD_AGENT_INTERVAL_SECONDS=10
# NETGUARD_AGENT_VERIFY_TLS=false
# NETGUARD_AGENT_HOME=C:\ProgramData\NetGuard
# NETGUARD_AGENT_CREDENTIAL_PATH=C:\ProgramData\NetGuard\credentials.json
# NETGUARD_AGENT_ENABLE_RESPONSE_ACTIONS=true
# NETGUARD_AGENT_ACTION_POLL_INTERVAL_SECONDS=30
# NETGUARD_AGENT_ALLOW_DESTRUCTIVE_RESPONSE_ACTIONS=false
# NETGUARD_AGENT_RESPONSE_POLICY_SECRET=replace-with-32-plus-random-characters
#
# Optional server-side policy gate for destructive response action queuing.
# Leave unset to fail closed. If enabled, approvals must include a short-lived
# HMAC signature built with this secret.
# NETGUARD_RESPONSE_POLICY_SECRET=replace-with-32-plus-random-characters
#
# Legacy runtime helpers remain available for netguard_agent:
# NETGUARD_MODE=legacy            # legacy | xdr | both
# NETGUARD_AGENT_KEY=nga_...      # host key issued by /api/agent/register
# NETGUARD_AGENT_BUFFER=.netguard-agent-buffer.jsonl
#
# Example:
# python -m netguard_agent --hub http://127.0.0.1:5000 --token <bootstrap> --mode xdr
#
# The new ./agent runtime stores the issued host key locally after first
# enrollment. Prefer short-lived nge_... enrollment tokens over long-lived
# admin tokens on endpoints.

############################
# CORS
############################

# Production should define explicit origins.
# IDS_CORS_ORIGINS=https://your-domain.example,https://www.your-domain.example

############################
# Logging and audit
############################

IDS_LOG_LEVEL=INFO
IDS_AUDIT_LOG=netguard_audit.log
IDS_AUDIT_LOG_ROTATE_WHEN=midnight
IDS_AUDIT_LOG_ROTATE_INTERVAL=1
IDS_AUDIT_LOG_RETENTION=14

# Shared admin rate-limit DB for the host.
# IDS_ADMIN_RL_DB=netguard_security.db

############################
# Background jobs
############################

# Background jobs start only in the intended bootstrap path.
# Enable explicitly in packaged/WGSI environments only when you want them.
# IDS_AUTOSTART_BACKGROUND=false
# IDS_AUTOSTART_SOC_ENGINE=false
# IDS_AUTOSTART_MONITOR=false
# IDS_AUTOSTART_TRIAL_SCHEDULER=false
# IDS_AUTOSTART_TI_FEED_SCHEDULER=false

############################
# Billing / Stripe
############################

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

############################
# SMTP
############################

# SMTP_HOST=smtp.your-provider.example
# SMTP_PORT=587
# SMTP_USER=noreply@your-domain.example
# SMTP_PASS=your_smtp_password
# SMTP_FROM=noreply@your-domain.example
# SMTP_STARTTLS=true
# SMTP_SSL=false

############################
# Optional enrichments and integrations
############################

# IDS_ABUSEIPDB_KEY=
# IDS_VIRUSTOTAL_KEY=
# IDS_AUTO_BLOCK=false
# IDS_WHITELIST_IPS=

############################
# Dashboard helper app
############################

# NETGUARD_DASHBOARD_SECRET_KEY=replace-with-a-strong-secret
# NETGUARD_DASHBOARD_USERNAME=admin
# NETGUARD_DASHBOARD_PASSWORD=replace-this-password
# NETGUARD_API_BASE=http://127.0.0.1:5000
# NETGUARD_DASHBOARD_TIMEOUT=5
# NETGUARD_DASHBOARD_DEBUG=false

# Optional token gate for the integrated /soc/grid EDR dashboard.
# NETGUARD_SOC_VIEW_TOKEN=replace-with-a-readonly-view-token
