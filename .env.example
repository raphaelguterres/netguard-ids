# ══════════════════════════════════════════════════════════════════
#  NetGuard IDS — Variáveis de ambiente
#  Copie para .env e preencha os valores. Nunca commite o .env!
# ══════════════════════════════════════════════════════════════════

# ── Banco de dados ────────────────────────────────────────────────
# Não definir = SQLite local (desenvolvimento / desktop)
# Definir     = PostgreSQL (produção / SaaS / VPS)
# DATABASE_URL=postgresql://netguard:senha@localhost:5432/netguard

# ── Stripe — Billing SaaS ─────────────────────────────────────────
# Pegue em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — gerado em: https://dashboard.stripe.com/webhooks
# Endpoint a registrar: https://seudominio.com/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — crie os produtos em: https://dashboard.stripe.com/products
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── URL pública da aplicação ──────────────────────────────────────
# Usado para construir redirect URLs no Stripe
APP_URL=https://seudominio.com

# ── Autenticação do dashboard ─────────────────────────────────────
# (se auth.py estiver habilitado)
# NETGUARD_USER=admin
# NETGUARD_PASS=senha_segura

# ── Porta ─────────────────────────────────────────────────────────
# PORT=5000
