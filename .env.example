# ══════════════════════════════════════════════════════════════════
#  NetGuard IDS — Variáveis de ambiente
#  Copie para .env e preencha os valores. NUNCA commite o .env!
#
#  Desenvolvimento: copie e ajuste conforme necessário
#  Produção:        todos os valores marcados com [PROD] são obrigatórios
# ══════════════════════════════════════════════════════════════════

# ── Banco de dados ────────────────────────────────────────────────
# Não definir = SQLite local (desenvolvimento / desktop)
# [PROD] Usar PostgreSQL gerenciado (Railway, Supabase, Render, RDS)
# DATABASE_URL=postgresql://netguard:SENHA_FORTE@localhost:5432/netguard

# ── Servidor ──────────────────────────────────────────────────────
IDS_HOST=0.0.0.0
IDS_PORT=5000
# [PROD] Habilita HTTPS_ONLY=true quando Nginx/TLS estiver na frente
HTTPS_ONLY=false

# ── Autenticação ──────────────────────────────────────────────────
# IDS_AUTH=false             → API pública (dev)
# IDS_AUTH=true              → API protegida por token
# IDS_DASHBOARD_AUTH=true    → Dashboard sempre exige login (recomendado em prod)
# IDS_DASHBOARD_AUTH=false   → Dev local sem autenticação
IDS_AUTH=false
IDS_DASHBOARD_AUTH=true

# [PROD] Desabilitar CSRF somente em testes automatizados
# IDS_CSRF_DISABLED=true

# ── CORS ──────────────────────────────────────────────────────────
# [PROD] Defina explicitamente as origens permitidas
# IDS_CORS_ORIGINS=https://seudominio.com,https://www.seudominio.com

# ── Logs e audit ──────────────────────────────────────────────────
IDS_LOG_LEVEL=INFO
# [PROD] Caminho para o arquivo de audit log (logins, criação de tenant, etc.)
IDS_AUDIT_LOG=netguard_audit.log

# ── Stripe — Billing SaaS ─────────────────────────────────────────
# Pegue em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — gerado em: https://dashboard.stripe.com/webhooks
# [PROD] Endpoint a registrar: https://seudominio.com/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — crie os produtos em: https://dashboard.stripe.com/products
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── URL pública da aplicação ──────────────────────────────────────
# [PROD] Usado para construir redirect URLs no Stripe e e-mails
APP_URL=https://seudominio.com

# ── E-mail transacional (boas-vindas, confirmações) ──────────────
# Funciona com qualquer provedor SMTP: Gmail, Mailgun, SendGrid,
# AWS SES, Resend (smtp.resend.com), Brevo (smtp-relay.brevo.com)…
# Se não definido, os e-mails são apenas logados (modo dry-run).
#
# Exemplo Gmail com App Password:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
#   SMTP_USER=seuconta@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx    ← App Password (não senha normal)
#
# Exemplo Resend (recomendado — gratuito até 3.000 e-mails/mês):
#   SMTP_HOST=smtp.resend.com  SMTP_PORT=587
#   SMTP_USER=resend  SMTP_PASS=re_...  SMTP_FROM=noreply@seudominio.com
#
# SMTP_HOST=smtp.seudominio.com
# SMTP_PORT=587
# SMTP_USER=noreply@seudominio.com
# SMTP_PASS=sua_senha_smtp
# SMTP_FROM=noreply@seudominio.com   # opcional, padrão = SMTP_USER
# SMTP_STARTTLS=true                 # true (padrão) ou false
# SMTP_SSL=false                     # true apenas para porta 465

# ── Certbot / Let's Encrypt ───────────────────────────────────────
# [PROD] Email para notificações de renovação de certificado
# CERTBOT_EMAIL=devops@seudominio.com

# ── Integrações opcionais ─────────────────────────────────────────
# IDS_ABUSEIPDB_KEY=         → Enriquecimento de IPs maliciosos
# IDS_VIRUSTOTAL_KEY=        → Análise de hashes de arquivos
# IDS_AUTO_BLOCK=false       → Bloqueio automático via iptables (Linux)
# IDS_WHITELIST_IPS=         → IPs confiáveis separados por vírgula

# Dashboard auxiliar (dashboard/app.py)
# Se usuario/senha nao forem definidos, o login por token continua disponivel.
# NETGUARD_DASHBOARD_SECRET_KEY=troque-por-um-valor-forte
# NETGUARD_DASHBOARD_USERNAME=admin
# NETGUARD_DASHBOARD_PASSWORD=troque-esta-senha
# NETGUARD_API_BASE=http://127.0.0.1:5000
# NETGUARD_DASHBOARD_TIMEOUT=5
# NETGUARD_DASHBOARD_DEBUG=false
